# TripNow 后端服务环境变量配置

# 服务器配置
PORT=3001
NODE_ENV=development

# 数据库配置（后续扩展）
# DATABASE_URL=postgresql://user:password@localhost:5432/tripnow

# JWT 配置（后续扩展）
# JWT_SECRET=your-secret-key-here
# JWT_EXPIRES_IN=7d

# CORS 配置
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# API 版本
API_VERSION=v1
